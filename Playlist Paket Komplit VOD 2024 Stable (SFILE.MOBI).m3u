.w3-bottom, .w3-top { position: fixed; width: 100%; z-index: 1; }

.w3-top { top: 0px; }

.w3-bottom { bottom: 0px; }

.w3-overlay { position: fixed; display: none; width: 100%; height: 100%; inset: 0px; background-color: rgba(0, 0, 0, 0.5); z-index: 2; }

.boxed, .konten-info { display: inline-block; vertical-align: top; }

.w3-display-topleft { position: absolute; left: 0px; top: 0px; }

.w3-display-topright { position: absolute; right: 0px; top: 0px; }

.w3-display-bottomleft { position: absolute; left: 0px; bottom: 0px; }

.w3-display-bottomright { position: absolute; right: 0px; bottom: 0px; }

.w3-display-middle { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); }

.w3-display-left { position: absolute; top: 50%; left: 0px; transform: translate(0px, -50%); }

.w3-display-right { position: absolute; top: 50%; right: 0px; transform: translate(0px, -50%); }

.w3-display-topmiddle { position: absolute; left: 50%; top: 0px; transform: translate(-50%, 0px); }

.w3-display-bottommiddle { position: absolute; left: 50%; bottom: 0px; transform: translate(-50%, 0px); }

.w3-display-position { position: absolute; }

.ad-label, .loginBtn, .w3-animate-left, .w3-animate-right, .w3-animate-top { position: relative; }

.w3-round-small { border-radius: 2px; }

