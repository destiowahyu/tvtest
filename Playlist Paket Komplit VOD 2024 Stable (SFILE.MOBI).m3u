@charset "utf-8";

.pl-ffb1cf3a0761b9ed9458f32ae2087538__link { text-decoration: none; color: rgb(18, 117, 236); border: 0px; outline: none; }

.pl-ffb1cf3a0761b9ed9458f32ae2087538__link img { border: none; }

.pl-ffb1cf3a0761b9ed9458f32ae2087538__finlink { position: absolute; width: 100%; height: 100%; left: 0px; right: 0px; z-index: 800; text-decoration: none; }

.pl-ffb1cf3a0761b9ed9458f32ae2087538__content { vertical-align: top; position: fixed; padding: 0px; width: 100%; display: none; box-sizing: border-box; left: 0px; right: 0px; margin: auto; height: 100%; top: 0px; align-items: center; justify-content: center; font-family: "San Francisco Text Regular"; }

.pl-ffb1cf3a0761b9ed9458f32ae2087538__content-block { display: inline-block; vertical-align: middle; position: relative; margin-top: 0px; padding: 0px; width: 314px; height: auto; font-size: 13px; border-radius: 12px; background: rgb(255, 255, 255); white-space: normal; z-index: 3; color: rgb(0, 0, 0); text-align: center; }

.pl-ffb1cf3a0761b9ed9458f32ae2087538__content-block .pl-ffb1cf3a0761b9ed9458f32ae2087538__title { text-align: center; color: rgb(0, 0, 0); font-size: 18px; line-height: 20px; padding: 20px 15px 10px; font-weight: 700; }

.pl-ffb1cf3a0761b9ed9458f32ae2087538__content-block .pl-ffb1cf3a0761b9ed9458f32ae2087538__message { padding: 0px 16px 20px; font-size: 14px; line-height: 17px; }

.pl-ffb1cf3a0761b9ed9458f32ae2087538__blur { content: ""; position: absolute; width: 100%; height: 100%; background: rgba(223, 223, 223, 0.4); top: 0px; left: 0px; right: 0px; margin: auto; z-index: -9; backdrop-filter: blur(6px); }

.pl-ffb1cf3a0761b9ed9458f32ae2087538__content-block .pl-ffb1cf3a0761b9ed9458f32ae2087538__message p { margin: 0px; }

.pl-ffb1cf3a0761b9ed9458f32ae2087538__action a { color: rgb(18, 117, 236); text-decoration: none; }

.pl-ffb1cf3a0761b9ed9458f32ae2087538__content-block .pl-ffb1cf3a0761b9ed9458f32ae2087538__action { border-top: 1px solid rgb(208, 208, 208); text-align: center; color: rgb(18, 117, 236); font-weight: 700; font-size: 18px; padding: 23px 0px; display: block; }

.pl-ffb1cf3a0761b9ed9458f32ae2087538__content-block .pl-ffb1cf3a0761b9ed9458f32ae2087538__content-block-wrap { position: fixed; inset: 0px; z-index: 10; }

