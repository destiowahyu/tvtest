.w3-round-large { border-radius: 8px; }

.w3-round-xlarge { border-radius: 16px; }

.w3-round-xxlarge { border-radius: 32px; }

.w3-row-padding, .w3-row-padding > .w3-col, .w3-row-padding > .w3-half, .w3-row-padding > .w3-quarter, .w3-row-padding > .w3-third, .w3-row-padding > .w3-threequarter, .w3-row-padding > .w3-twothird { padding: 0px 8px; }

.w3-container, .w3-panel { padding: 0.01em 16px; }

.w3-panel { margin-top: 16px; margin-bottom: 16px; }

.w3-code, .w3-margin-top, .w3-section { margin-top: 16px !important; }

.w3-code, .w3-margin-bottom, .w3-section { margin-bottom: 16px !important; }

.w3-code, .w3-codespan { font-family: Consolas, "courier new"; font-size: 16px; }

.w3-code { width: auto; background-color: rgb(255, 255, 255); padding: 8px 12px; border-left: 4px solid rgb(76, 175, 80); overflow-wrap: break-word; }

.w3-animate-input:focus, fb-comments { width: 100% !important; }

.w3-codespan { color: rgb(220, 20, 60); background-color: rgb(241, 241, 241); padding-left: 4px; padding-right: 4px; font-size: 110%; }

.w3-card, .w3-card-2 { box-shadow: rgba(0, 0, 0, 0.16) 0px 2px 5px 0px, rgba(0, 0, 0, 0.12) 0px 2px 10px 0px; }

.w3-card-4, .w3-hover-shadow:hover { box-shadow: rgba(0, 0, 0, 0.2) 0px 4px 10px 0px, rgba(0, 0, 0, 0.19) 0px 4px 20px 0px; }

.w3-spin { animation: 2s linear 0s infinite normal none running w3-spin; }

@keyframes w3-spin { 
  0% { transform: rotate(0deg); }
  100% { transform: rotate(359deg); }
}

.w3-animate-fading { animation: 10s ease 0s infinite normal none running fading; }

@keyframes fading { 
  0%, 100% { opacity: 0; }
  50% { opacity: 1; }
}

.w3-animate-opacity { animation: 0.8s ease 0s 1 normal none running opac; }

@keyframes opac { 
  0% { opacity: 0; }
  100% { opacity: 1; }
}

.w3-animate-top { animation: 0.4s ease 0s 1 normal none running animatetop; }

@keyframes animatetop { 
  0% { top: -300px; opacity: 0; }
  100% { top: 0px; opacity: 1; }
}

.w3-animate-left { animation: 0.4s ease 0s 1 normal none running animateleft; }

@keyframes animateleft { 
  0% { left: -300px; opacity: 0; }
  100% { left: 0px; opacity: 1; }
}

.w3-animate-right { animation: 0.4s ease 0s 1 normal none running animateright; }

@keyframes animateright { 
  0% { right: -300px; opacity: 0; }
  100% { right: 0px; opacity: 1; }
}

.w3-animate-bottom { position: relative; animation: 0.4s ease 0s 1 normal none running animatebottom; }

@keyframes animatebottom { 
  0% { bottom: -300px; opacity: 0; }
  100% { bottom: 0px; opacity: 1; }
}

.w3-animate-zoom { animation: 0.6s ease 0s 1 normal none running animatezoom; }

@keyframes animatezoom { 
  0% { transform: scale(0); }
  100% { transform: scale(1); }
}

.w3-animate-input { transition: width 0.4s ease-in-out; }

.w3-hover-opacity:hover, .w3-opacity { opacity: 0.6; }

.w3-hover-opacity-off:hover, .w3-opacity-off { opacity: 1; }

.w3-opacity-max { opacity: 0.25; }

.w3-opacity-min { opacity: 0.75; }

